<mvc:View controllerName="com.nbx.trainerlist.controller.Main"
    displayBlock="true"
    height="100%"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>TITLE_TRAINERS}">
        <content>
            <Table id="trainersTable" items="{/Trainers}">
                <columns>
                    <Column><Text text="{i18n>COLUMN_FIRST_NAME}" /></Column>
                    <Column><Text text="{i18n>COLUMN_LAST_NAME}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press=".onPressTrainer">
                        <cells>
                            <Text text="{FirstName}" />
                            <Text text="{LastName}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button text="{i18n>BUTTON_ADD_TEAM}"
                press=".onAddTeam"
                visible="{userConfig>/canCreate}"/>
                <Button
                    text="{i18n>BUTTON_ADD_TRAINER}"
                    press=".onAddTrainer"
                    visible="{userConfig>/canCreate}"/>
                    <Button
                    text="{i18n>BUTTON_POKEMONS}"
                    press=".onImportPokemon"
                    visible="{userConfig>/canCapture}"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>