<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Dialog
        id="addTrainerDialog"
        title="Add Trainer"
        contentWidth="400px">

        <content>
            <l:VerticalLayout width="100%" class="sapUiSmallMargin">

                <Input
                    id="inputFirstName"
                    placeholder="First Name"
                    width="90%"/>

                <Input
                    id="inputLastName"
                    placeholder="Last Name"
                    width="90%"/>

                <Input
                    id="inputEmail"
                    placeholder="Email"
                    width="90%"/>

            </l:VerticalLayout>
        </content>

        <beginButton>
            <Button
                text="Save"
                type="Emphasized"
                press=".onSaveTrainer"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCancelTrainer"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
