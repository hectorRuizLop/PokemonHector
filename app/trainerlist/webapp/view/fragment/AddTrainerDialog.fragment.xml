<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Dialog
        id="addTrainerDialog"
        title="{util>TITLE_ADD_TRAINER}"
        contentWidth="400px">

        <content>
            <l:VerticalLayout width="100%" class="sapUiSmallMargin">

                <Input
                    id="inputFirstName"
                    placeholder="{i18n>PLACEHOLDER_FIRST_NAME}"
                    width="90%"/>

                <Input
                    id="inputLastName"
                    placeholder="{i18n>PLACEHOLDER_LAST_NAME}"
                    width="90%"/>

                <Input
                    id="inputEmail"
                    placeholder="{i18n>PLACEHOLDER_EMAIL}"
                    width="90%"/>

            </l:VerticalLayout>
        </content>

        <beginButton>
            <Button
                text="{i18n>BUTTON_SAVE}"
                type="Emphasized"
                press=".onSaveTrainer"/>
        </beginButton>

        <endButton>
            <Button
                text="{i18n>BUTTON_CANCEL}"
                press=".onCancelTrainer"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
