<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Table id="capturesTable" items="{captures}">
        <columns>
            <Column><Text text="{i18n>COLUMN_POKEMON}" /></Column>
            <Column><Text text="{i18n>COLUMN_WEIGHT}" /></Column>
            <Column><Text text="{i18n>COLUMN_HEIGHT}" /></Column>
        </columns>
        <items>
            <ColumnListItem type="Inactive">
                <cells>
                    <Text text="{PokemonName}" />
                    <Text text="{Weight}" />
                    <Text text="{Height}" />
                </cells>
            </ColumnListItem>
        </items>
    </Table>

</core:FragmentDefinition>
