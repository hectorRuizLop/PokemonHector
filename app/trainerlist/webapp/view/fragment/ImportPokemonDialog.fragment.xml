<!-- webapp/view/fragment/ImportPokemonDialog.fragment.xml -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    
    <Dialog id="importPokemonDialog" title="Pokemon">
        <content>
            <VBox class="sapUiSmallMargin">

                <form:SimpleForm>
                    <form:content>
                        <Label text="Name"/>
                        <Text id="txtPokemonName" text=""/>
                        
                        <Label text="Heihgt"/>
                        <Text id="txtPokemonHeight" text=""/>
                        
                        <Label text="Weight"/>
                        <Text id="txtPokemonWeight" text=""/>
                    </form:content>
                </form:SimpleForm>

                <Label text="Which team do you want to add it??" class="sapUiSmallMarginTop"/>
                <Select id="selectTeam" items="{/Teams}">
                    <core:Item key="{ID}" text="{Name}"/>
                </Select>
                
            </VBox>
        </content>
        
        <beginButton>
            <Button text="Capture" press=".onConfirmCapture" type="Accept"/>
        </beginButton>
        <endButton>
            <Button text="Not capture" press=".onCancelCapture" type="Reject"/>
        </endButton>
    </Dialog>
    
</core:FragmentDefinition>
