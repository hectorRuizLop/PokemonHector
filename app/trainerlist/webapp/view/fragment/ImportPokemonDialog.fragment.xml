<!-- webapp/view/fragment/ImportPokemonDialog.fragment.xml -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form">
    
    <Dialog id="importPokemonDialog" title="{i18n>TITLE_POKEMON_DIALOG}">
        <content>
            <VBox class="sapUiSmallMargin">

                <form:SimpleForm>
                    <form:content>
                        <Label text="{i18n>LABEL_POKEMON_NAME}"/>
                        <Text id="txtPokemonName" text=""/>
                        
                        <Label text="{i18n>LABEL_HEIGHT}"/>
                        <Text id="txtPokemonHeight" text=""/>
                        
                        <Label text="{i18n>LABEL_WEIGHT}"/>
                        <Text id="txtPokemonWeight" text=""/>
                    </form:content>
                </form:SimpleForm>

                <Label text="{i18n>LABEL_SELECT_TEAM}" class="sapUiSmallMarginTop"/>
                <Select id="selectTeam" items="{/Teams}">
                    <core:Item key="{ID}" text="{Name}"/>
                </Select>
                
            </VBox>
        </content>
        
        <beginButton>
            <Button text="{i18n>BUTTON_CAPTURE}" press=".onConfirmCapture" type="Accept"/>
        </beginButton>
        <endButton>
            <Button text="{i18n>BUTTON_NOT_CAPTURE}" press=".onCancelCapture" type="Reject"/>
        </endButton>
    </Dialog>
    
</core:FragmentDefinition>
