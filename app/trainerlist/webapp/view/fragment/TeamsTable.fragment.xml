<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Table id="teamsTable" items="{teams}">
        <columns>
            <Column><Text text="{i18n>COLUMN_NAME}" /></Column>
            <Column><Text text="{i18n>COLUMN_DESCRIPTION}" /></Column>
            <Column><Text text="{i18n>COLUMN_ACTIVE}" /></Column>
        </columns>
        <items>
            <ColumnListItem type="Navigation" press=".onPressTeam">
                <cells>
                    <Text text="{Name}" />
                    <Text text="{Description}" />
                    <CheckBox selected="{Active}" editable="false" />
                </cells>
            </ColumnListItem>
        </items>
    </Table>

</core:FragmentDefinition>
